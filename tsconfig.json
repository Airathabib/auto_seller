{
	"compilerOptions": {
		"target": "ES2017",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"baseUrl": ".",
		"types": ["node"],
		// Строгость типизации
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"paths": {
			"@/*": ["./src/*"],
			// Исправлено: иконки должны быть в src для работы SVGR
			"@icons/*": ["./src/assets/icons/*"],
			// Исправлено: поддержка импорта из папки стора
			"@store/*": ["./src/app/providers/StoreProvider/config/store/*"],
			"@store": ["./src/app/providers/StoreProvider/config/store/index"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		"**/*.mts",
		".next/types/**/*.ts",
		"src",
		".next/dev/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
